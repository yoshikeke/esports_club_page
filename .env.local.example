# ============================================================
# 熊本高専 eスポーツ同好会 - 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください
# ============================================================

# ---- Notion API ----
# https://www.notion.so/my-integrations で取得
NOTION_TOKEN=secret_xxxx

# Notion データベース ID (URLの末尾32文字)
# 例: https://notion.so/workspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
NOTION_BLOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_EVENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Google Forms (お問い合わせ) ----
# Google Forms → 送信 → <> → 埋め込みHTMLの src= の値をコピー
NEXT_PUBLIC_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/XXXX/viewform?embedded=true

# ---- Google Drive (資料・記録ページ) ----
# フォルダ: Google Drive フォルダ → 共有 → リンクをコピー後、以下の形式に変換
# https://drive.google.com/embeddedfolderview?id=YOUR_FOLDER_ID#list
NEXT_PUBLIC_DRIVE_FOLDER_URL=https://drive.google.com/embeddedfolderview?id=YOUR_FOLDER_ID#list

# スライドなど個別ファイル (オプション)
# https://drive.google.com/file/d/YOUR_FILE_ID/preview
NEXT_PUBLIC_DRIVE_SLIDE_URL=https://drive.google.com/file/d/YOUR_FILE_ID/preview
